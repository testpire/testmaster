# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# TestPire REST API base URL (used by src/lib/apiClient.js).
VITE_API_BASE_URL=http://localhost:8080/api

# Legacy Supabase (the app has migrated off Supabase; only needed if USE_NEW_API=false).
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Optional third-party integrations.
VITE_OPENAI_API_KEY=your-openai-api-key-here
VITE_GEMINI_API_KEY=your-gemini-api-key-here
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
VITE_GOOGLE_ANALYTICS_ID=your-google-analytics-id-here
VITE_ADSENSE_ID=your-adsense-id-here
VITE_PERPLEXITY_API_KEY=your-perplexity-api-key-here
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
